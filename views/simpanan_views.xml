<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_simpanan_syariah_form" model="ir.ui.view">
        <field name="name">ksp.simpanan.syariah.form</field>
        <field name="model">ksp.simpanan.syariah</field>
        <field name="arch" type="xml">
            <form string="Simpanan Syariah">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <field name="anggota_id"/>
                        <field name="jenis_simpanan"/>
                        <field name="saldo"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_simpanan_syariah_list" model="ir.ui.view">
        <field name="name">ksp.simpanan.syariah.list</field>
        <field name="model">ksp.simpanan.syariah</field>
        <field name="arch" type="xml">
            <list string="Simpanan Syariah">
                <field name="name"/>
                <field name="anggota_id"/>
                <field name="jenis_simpanan"/>
                <field name="saldo"/>
            </list>
        </field>
    </record>

    <record id="action_simpanan_syariah" model="ir.actions.act_window">
        <field name="name">Simpanan Syariah</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">ksp.simpanan.syariah</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
